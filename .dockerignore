# Evita copiar artefactos locales a la imagen.
.git
.gitignore
.venv
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.idea/
.vscode/
*.log
*.sqlite3
db.sqlite3
media/
staticfiles/

# Secrets locales: las vars se inyectan vía env_file en docker-compose
.env
.env.*
!.env.example

# Docker se construye desde acá; no recursivo
docker-compose*.yml
Dockerfile
